FROM node:20-alpine
WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Install dependencies first — layer is cached unless lockfile changes
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Source code is mounted as a volume at runtime (see docker-compose.yml)
# so we don't COPY . . here — that would be stale on every code change

EXPOSE 3000

CMD ["pnpm", "dev"]
